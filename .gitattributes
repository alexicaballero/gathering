# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.cs text eol=crlf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.csproj text eol=crlf
*.sln text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
